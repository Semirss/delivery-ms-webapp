# Root .gitignore for the monorepo

# Environment variables - NEVER commit these
webapp/.env.local
webapp/.env
telegram-bot/.env
**/.env.local
**/.env

# Android release signing secrets - NEVER commit these
**/android/key.properties
**/android/app/upload-keystore.jks
**/*.jks
**/*.keystore

# Dependency directories
**/node_modules/
**/__pycache__/
**/*.pyc
**/venv/
**/.venv/

# Build outputs
webapp/.next/
webapp/out/

# Misc
.DS_Store
*.log
Thumbs.db
