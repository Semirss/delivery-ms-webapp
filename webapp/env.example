NEXT_PUBLIC_SUPABASE_URL=https://your-current-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-current-anon-key
SUPABASE_URL=https://your-current-project.supabase.co
SUPABASE_ANON_KEY=your-current-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-current-service-role-key

# Optional master Supabase used to rotate active backend config.
# Public/mobile apps read only URL + anon key from the public view.
MASTER_SUPABASE_URL=https://your-master-project.supabase.co
MASTER_SUPABASE_ANON_KEY=your-master-anon-key
MASTER_SUPABASE_SERVICE_ROLE_KEY=your-master-service-role-key
MASTER_BACKEND_CONFIG_TABLE=backend_runtime_config
MASTER_BACKEND_CONFIG_VIEW=public_backend_runtime_config

# Defaults to 1212 if omitted.
ADMIN_BACKEND_PASS=1212
