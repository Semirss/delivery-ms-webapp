# ============================================================
# MOTOBIKE CLIENT App - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control!
# ============================================================

# --- Supabase (REQUIRED) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Optional master Supabase used to rotate the active backend without
# rebuilding the app. If unset/unreachable, the app falls back to the
# SUPABASE_URL and SUPABASE_ANON_KEY above.
MASTER_SUPABASE_URL=https://your-master-project-ref.supabase.co
MASTER_SUPABASE_ANON_KEY=your-master-anon-key-here
MASTER_BACKEND_CONFIG_VIEW=public_backend_runtime_config

# --- App ---
ENVIRONMENT=development
APP_NAME=MOTOBIKE

# --- Web API (REQUIRED for admin-controlled app version checks) ---
# Use the deployed webapp URL. Local example: http://localhost:3000
API_BASE_URL=https://www.motobikedeliveryservice.com
API_TIMEOUT=30000

# --- Monitoring (Optional) ---
# Leave blank unless you have a real Sentry project DSN.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Feature Flags ---
ENABLE_LOGGING=true
ENABLE_CHUCK_INTERCEPTOR=true
